{
  "name": "exocortex-daemon",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun run --watch src/main.ts",
    "login": "bun run src/main.ts login",
    "test": "bun test",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "coverage": "bun test --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@exocortex/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7"
  }
}
