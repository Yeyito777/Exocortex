#!/usr/bin/env bash
# exocortex — Exocortex TUI client.
# Thin wrapper that resolves the project root and runs the TUI entry point.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
SERVICE="exocortex-daemon.service"

resolve_git_path() {
  case "$1" in
    /*) realpath "$1" 2>/dev/null || printf '%s\n' "$1" ;;
    *) realpath "$PROJECT_DIR/$1" 2>/dev/null || printf '%s\n' "$PROJECT_DIR/$1" ;;
  esac
}

detect_worktree_name() {
  local git_dir git_common_dir
  if ! git_dir="$(git -C "$PROJECT_DIR" rev-parse --git-dir 2>/dev/null)"; then
    return 0
  fi
  if ! git_common_dir="$(git -C "$PROJECT_DIR" rev-parse --git-common-dir 2>/dev/null)"; then
    return 0
  fi
  git_dir="$(resolve_git_path "$git_dir")"
  git_common_dir="$(resolve_git_path "$git_common_dir")"
  if [[ "$git_dir" != "$git_common_dir" ]]; then
    basename "$git_dir"
  fi
}

runtime_dir() {
  local config_dir wt
  config_dir="${EXOCORTEX_CONFIG_DIR:-$PROJECT_DIR/config}"
  wt="$(detect_worktree_name)"
  if [[ -n "${wt:-}" ]]; then
    printf '%s\n' "$config_dir/runtime/$wt"
  else
    printf '%s\n' "$config_dir/runtime"
  fi
}

socket_path() {
  printf '%s\n' "$(runtime_dir)/exocortexd.sock"
}

ensure_daemon() {
  local sock
  sock="$(socket_path)"
  if [[ -S "$sock" ]]; then
    return 0
  fi

  if [[ -f "$HOME/.config/systemd/user/$SERVICE" ]]; then
    systemctl --user start "$SERVICE" >/dev/null 2>&1 || true
    for _ in {1..40}; do
      if [[ -S "$sock" ]]; then
        return 0
      fi
      sleep 0.2
    done

    {
      echo "  ✗ exocortexd did not come up."
      systemctl --user status "$SERVICE" --no-pager || true
      echo
      journalctl --user -u "$SERVICE" -n 20 --no-pager || true
    } >&2
    return 1
  fi
}

ensure_daemon

cd "$PROJECT_DIR/tui"
exec bun run src/main.ts "$@"
