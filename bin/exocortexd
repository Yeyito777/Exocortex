#!/usr/bin/env bash
# exocortexd — Exocortex daemon.
# Thin wrapper that resolves the project root and runs the daemon entry point.
# Service subcommands use systemctl on Linux and launchctl on macOS.
# Restart gracefully interrupts active streams and replays them after boot.
# Stop flushes/aborts active work but deliberately leaves nothing to resume.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
SERVICE="exocortex-daemon.service"
LAUNCHD_LABEL="${EXOCORTEX_LAUNCHD_LABEL:-com.exocortex.daemon}"
RED=$'\033[31m'
RESET=$'\033[0m'

print_error() {
  if [[ -t 2 ]]; then
    printf '  %s✗%s %s\n' "$RED" "$RESET" "$1" >&2
  else
    printf '  ✗ %s\n' "$1" >&2
  fi
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

launchd_domain() {
  printf 'gui/%s' "$(id -u)"
}

launchd_target() {
  printf '%s/%s' "$(launchd_domain)" "$LAUNCHD_LABEL"
}

launchd_plist() {
  printf '%s/Library/LaunchAgents/%s.plist' "$HOME" "$LAUNCHD_LABEL"
}

daemon_socket_path() {
  printf '%s/config/runtime/exocortexd.sock' "$PROJECT_DIR"
}

launchd_service_is_loaded() {
  launchctl print "$(launchd_target)" >/dev/null 2>&1
}

launchd_status_output() {
  launchctl print "$(launchd_target)" 2>/dev/null || true
}

launchd_service_is_running() {
  local status
  status="$(launchd_status_output)"
  grep -q "state = running" <<< "$status"
}

launchd_status_field() {
  local field="$1"
  sed -n "s/^[[:space:]]*$field = //p" | head -n 1
}

print_launchd_summary() {
  local status state pid runs last_exit socket log
  status="$(launchd_status_output)"
  state="$(printf '%s\n' "$status" | launchd_status_field "state")"
  pid="$(printf '%s\n' "$status" | launchd_status_field "pid")"
  runs="$(printf '%s\n' "$status" | launchd_status_field "runs")"
  last_exit="$(printf '%s\n' "$status" | launchd_status_field "last exit code")"
  socket="$(daemon_socket_path)"
  log="$PROJECT_DIR/config/runtime/launchd.out.log"

  echo "  • LaunchAgent: $LAUNCHD_LABEL (${state:-unknown})"
  [[ -n "$pid" ]] && echo "  • PID: $pid"
  [[ -n "$runs" ]] && echo "  • Runs: $runs"
  [[ -n "$last_exit" ]] && echo "  • Last exit: $last_exit"
  if [[ -S "$socket" ]]; then
    echo "  • Socket: $socket"
  else
    echo "  • Socket: not ready yet ($socket)"
  fi
  echo "  • Logs: $log"
  echo "  • Details: exocortexd status --verbose"
}

wait_for_launchd_running() {
  for _ in {1..50}; do
    if launchd_service_is_running; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

wait_for_daemon_socket() {
  local socket
  socket="$(daemon_socket_path)"
  for _ in {1..100}; do
    if [[ -S "$socket" ]]; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

ensure_launchd_service_loaded() {
  if launchd_service_is_loaded; then
    return
  fi

  local plist
  plist="$(launchd_plist)"
  if [[ ! -f "$plist" ]]; then
    print_error "LaunchAgent not found: $plist"
    echo "    Install the daemon LaunchAgent first, then retry." >&2
    exit 1
  fi

  launchctl bootstrap "$(launchd_domain)" "$plist"
  launchctl enable "$(launchd_target)" 2>/dev/null || true
}

restart_service() {
  if is_macos; then
    ensure_launchd_service_loaded
    launchctl kickstart -k "$(launchd_target)"
    if ! wait_for_launchd_running; then
      print_error "Timed out waiting for LaunchAgent to restart: $(launchd_target)"
      print_launchd_summary >&2
      exit 1
    fi
    wait_for_daemon_socket || true
    echo "  ✓ Restarted"
    print_launchd_summary
  else
    systemctl --user restart "$SERVICE"
    echo "  ✓ Restarted"
    systemctl --user status "$SERVICE" --no-pager
  fi
}

start_service() {
  if is_macos; then
    ensure_launchd_service_loaded
    if launchd_service_is_running; then
      echo "  • Already running"
      print_launchd_summary
      return
    fi
    launchctl kickstart "$(launchd_target)"
    if ! wait_for_launchd_running; then
      print_error "Timed out waiting for LaunchAgent to start: $(launchd_target)"
      print_launchd_summary >&2
      exit 1
    fi
    wait_for_daemon_socket || true
    echo "  ✓ Started"
    print_launchd_summary
  else
    systemctl --user start "$SERVICE"
    echo "  ✓ Started"
    systemctl --user status "$SERVICE" --no-pager
  fi
}

stop_service() {
  if is_macos; then
    if ! launchd_service_is_loaded; then
      echo "  • Not loaded"
      return
    fi

    if launchd_service_is_running; then
      launchctl kill TERM "$(launchd_target)" 2>/dev/null || true
      for _ in {1..50}; do
        if ! launchd_service_is_running; then
          break
        fi
        sleep 0.1
      done
    fi

    if launchd_service_is_running; then
      print_error "Timed out waiting for LaunchAgent to stop: $(launchd_target)"
      exit 1
    fi

    echo "  ✓ Stopped"
  else
    systemctl --user stop "$SERVICE"
    echo "  ✓ Stopped"
  fi
}

status_service() {
  if is_macos; then
    local verbose=0
    while (($# > 0)); do
      case "$1" in
        -v|--verbose)
          verbose=1
          ;;
        *)
          print_error "Unknown status option: $1"
          echo "    Usage: exocortexd status [--verbose|-v]" >&2
          exit 2
          ;;
      esac
      shift
    done

    if ! launchd_service_is_loaded; then
      print_error "LaunchAgent is not loaded: $(launchd_target)"
      local plist
      plist="$(launchd_plist)"
      [[ -f "$plist" ]] && echo "    plist: $plist" >&2
      exit 3
    fi
    if (( verbose == 1 )); then
      launchctl print "$(launchd_target)"
    else
      print_launchd_summary
    fi
  else
    systemctl --user status "$SERVICE" --no-pager
  fi
}

service_is_active() {
  if is_macos; then
    launchd_service_is_running
  else
    systemctl --user is-active --quiet "$SERVICE"
  fi
}

prepare_restart_for_replay() {
  (
    cd "$PROJECT_DIR/daemon"
    bun run src/main.ts prepare-restart
  )
}

prepare_stop_without_replay() {
  (
    cd "$PROJECT_DIR/daemon"
    bun run src/main.ts prepare-stop
  )
}

cancel_stop_recovery() {
  (
    cd "$PROJECT_DIR/daemon"
    bun run src/main.ts cancel-recovery
  )
}

join_ids() {
  local joined=""
  local id
  for id in "$@"; do
    if [[ -n "$joined" ]]; then
      joined+=", "
    fi
    joined+="$id"
  done
  printf '%s' "$joined"
}

handle_restart() {
  local force=0

  while (($# > 0)); do
    case "$1" in
      -f|--force)
        force=1
        ;;
      *)
        print_error "Unknown restart option: $1"
        echo "    Usage: exocortexd restart [--force|-f]" >&2
        exit 2
        ;;
    esac
    shift
  done

  if (( force == 0 )) && service_is_active; then
    local interrupted_output
    if ! interrupted_output="$(prepare_restart_for_replay)"; then
      print_error "Failed to prepare running conversations for replay; use --force to override"
      exit 1
    fi

    local interrupted_ids=()
    local line
    while IFS= read -r line; do
      [[ -n "$line" ]] && interrupted_ids+=("$line")
    done <<< "$interrupted_output"

    if ((${#interrupted_ids[@]} > 0)); then
      echo "  • Interrupted and scheduled replay: $(join_ids "${interrupted_ids[@]}")"
    fi
  fi

  restart_service
}

handle_stop() {
  if service_is_active; then
    if ! prepare_stop_without_replay; then
      echo "  ⚠ Live daemon did not accept stop preparation; stopping it and clearing recovery state afterwards" >&2
    fi
  fi
  stop_service
  # Run after the process exits too: this makes the first stop after upgrading
  # safe even when the old daemon treated SIGTERM as restart-worthy.
  cancel_stop_recovery
}

case "${1:-}" in
  start)
    start_service
    ;;
  restart)
    shift
    handle_restart "$@"
    ;;
  stop)
    handle_stop
    ;;
  status)
    shift
    status_service "$@"
    ;;
  *)
    exec "$PROJECT_DIR/scripts/setup/run-daemon.sh" "$@"
    ;;
esac
