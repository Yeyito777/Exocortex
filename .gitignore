# Dependencies
node_modules/

# Build/test output
dist/
build/
coverage/
.tmp/
tmp/

# Worktrees and local runtime data
.worktrees/
.exocortex-cwd/*
!.exocortex-cwd/.gitkeep
.rsync-filter
config/config.json
config/data/
config/runtime/
config/storage/
config/secrets/
config/secrets

# Legacy cron jobs are local migration input. Chrono scripts remain local.
config/cron/*
config/chrono/*
!config/chrono/.gitkeep

# External tools are installed/generated locally; keep documentation tracked
external-tools/*
!external-tools/TOOL_STANDARD.md
!external-tools/PORT_PROMPT.md

# Environment and secrets
.env
.env.*
*.env
*.secret
*.secrets

# Logs and locks
*.log
*.lock*

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
